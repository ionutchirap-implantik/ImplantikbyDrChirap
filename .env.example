LEAD_NOTIFY_TO=            # emailul clinicii care primește notificările
LEAD_NOTIFY_FROM=          # expeditor verificat în Resend, ex. Implantik <implantikdrchirap@gmail.com>

# Tracking — încărcat DOAR după consimțământ CMP
NEXT_PUBLIC_GTM_ID=GTM-5QFHBCH
NEXT_PUBLIC_GTM_SERVER_URL=[GTM_SERVER_URL]
NEXT_PUBLIC_GA4_ID=[GA4_ID]
